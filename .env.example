# Kronos 환경변수 예시
# 실제 값은 .env로 복사 후 채워넣기 (.env는 git에서 제외됨)
#
# 발급:
#   - DART:   https://opendart.fss.or.kr
#   - 네이버:  https://developers.naver.com (검색 API)

# DART Open API
DART_API_KEY=your-dart-api-key-here

# Naver 검색 API
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 로깅 (옵션)
LOG_LEVEL=INFO

# KIS는 Phase 4 진입 시 추가 — Phase 0~3에서는 불필요
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ENV=paper
